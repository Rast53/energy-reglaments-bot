# energy-reglaments-bot — copy to .env and fill values
# Secrets: /root/.openclaw/credentials/energy-reglaments-bot.env

# Telegram
BOT_TOKEN=                    # from @BotFather
BOT_USERNAME=orem_reglaments_bot

# OpenRouter (embeddings + LLM)
OPENROUTER_API_KEY=           # sk-or-v1-...

# OpenClaw sidecar
OPENCLAW_URL=http://openclaw:18789
OPENCLAW_API_KEY=             # generated, set in openclaw config

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=               # optional, leave empty for internal network

# PostgreSQL
DATABASE_URL=postgresql://energy:energy@postgres:5432/energy
POSTGRES_USER=energy
POSTGRES_PASSWORD=energy
POSTGRES_DB=energy

# Crawler settings
CRAWLER_VERIFY_SSL=false      # np-sr.ru has broken SSL
CRAWLER_BASE_URL=https://www.np-sr.ru
CRAWLER_DELAY_SEC=2           # delay between requests

# Indexer settings
EMBEDDING_MODEL=openai/text-embedding-3-large
QDRANT_COLLECTION=reglaments
QDRANT_VECTOR_SIZE=3072

# Bot settings
ADMIN_IDS=125525685           # Telegram user IDs allowed to use /update
LOG_LEVEL=INFO

# Deploy
NODE_ENV=production
